TELEGRAM_TOKEN_CLAUDE=replace-with-telegram-bot-token
TELEGRAM_TOKEN_CODEX=replace-with-telegram-bot-token

CLAUDE_BOT_NAME=ClaudeCodeBot
CLAUDE_CLI_EXECUTABLE=claude
CLAUDE_CLI_ARGS=-p
CLAUDE_MENTION_ALIASES=@ClaudeCodeBot

CODEX_BOT_NAME=CodexPairBot
CODEX_CLI_EXECUTABLE=codex
CODEX_CLI_ARGS=
CODEX_MENTION_ALIASES=@CodexPairBot

TELEGRAM_PAIR_WORKSPACE_DIR=./runtime
# Optional override if you want the context file elsewhere.
# TELEGRAM_PAIR_CONTEXT_PATH=./runtime/context.md

TELEGRAM_PAIR_TIMEOUT_SECONDS=180
TELEGRAM_PAIR_MAX_CONTEXT_TURNS=12
TELEGRAM_PAIR_DEDUP_TTL_SECONDS=300
# Optional: restrict processing to one Telegram chat/group id.
# TELEGRAM_PAIR_TARGET_CHAT_ID=-1001234567890
TELEGRAM_PAIR_LOG_LEVEL=INFO
